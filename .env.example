# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── Database (PostgreSQL on DigitalOcean / Railway) ─────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/gridbot

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRES_IN=7d

# ─── Encryption key for storing broker credentials (AES-256) ─────────────────
# Must be exactly 32 characters
ENCRYPTION_KEY=CHANGE_THIS_32_CHAR_SECRET_KEY__

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ─── Token refresh schedule (IST = UTC+5:30) ─────────────────────────────────
# Cron: every day at 8:00 AM IST = 2:30 AM UTC
TOKEN_REFRESH_CRON=30 2 * * 1-5

# ─── NSE/BSE script master refresh (6:00 AM IST = 12:30 AM UTC) ──────────────
SCRIPT_REFRESH_CRON=30 0 * * 1-5
